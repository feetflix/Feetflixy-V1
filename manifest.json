{
  "manifest_version": 2,

  "name": "FeetFlixy",
  "version": "1.0.0",
  "description": "Netflix account manager",
  "permissions": [
    "storage",
    "activeTab",
    "cookies",
    "tabs",
    "storage",
    "https://www.netflix.com/*",
    "https://cookie-server-feetflixs-projects.vercel.app/*"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icon.png", "128": "icon.png" }
  },
  "icons": { "48": "icon.png", "128": "icon.png" },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  }
}